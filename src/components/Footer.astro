---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="logo">
          <span class="logo-icon">
            <span class="logo-dot"></span>
          </span>
          <span class="logo-text">PROXIMA</span>
        </a>
        <p class="footer-desc">
          テクノロジーで、次の当たり前をつくる。<br />株式会社プロキシマ
        </p>
      </div>

      <div class="footer-col">
        <div class="footer-col-label">COMPANY</div>
        <div class="footer-col-links">
          <a href="/about/">会社情報</a>
          <a href="/news/">ニュース</a>
          <a href="/contact/">採用情報</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-label">CONTACT</div>
        <div class="footer-col-links">
          <a href="/contact/">お問い合わせ</a>
          <a href="/admin/">CMS管理画面</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-label">FOLLOW</div>
        <div class="footer-col-links">
          <span>X / Twitter</span>
          <span>LinkedIn</span>
          <span>GitHub</span>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} PROXIMA Inc. All rights reserved.</span>
      <div class="footer-legal">
        <span>プライバシーポリシー</span>
        <span>利用規約</span>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    background: #05091c;
    color: #fff;
    padding: 80px 0 36px;
  }
  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 54px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 11px;
    color: #fff;
    text-decoration: none;
  }
  .logo-icon {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: linear-gradient(135deg, #2f6bff, #7fa8ff);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .logo-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: 2.5px solid #fff;
    display: block;
  }
  .logo-text {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 21px;
  }
  .footer-desc {
    font-size: 14px;
    line-height: 1.9;
    color: rgba(200, 212, 240, 0.6);
    margin-top: 18px;
    max-width: 280px;
  }
  .footer-col-label {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.1em;
    color: #5e6c90;
    margin-bottom: 18px;
  }
  .footer-col-links {
    display: flex;
    flex-direction: column;
    gap: 13px;
  }
  .footer-col-links a,
  .footer-col-links span {
    font-size: 14px;
    color: rgba(220, 228, 245, 0.8);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-col-links a:hover {
    color: #fff;
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
    padding-top: 30px;
  }
  .footer-bottom span {
    font-size: 13px;
    color: rgba(200, 212, 240, 0.5);
  }
  .footer-legal {
    display: flex;
    gap: 24px;
    font-size: 13px;
    color: rgba(200, 212, 240, 0.5);
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
